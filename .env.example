# Backend Environment Configuration
# Copy this file to .env and update values as needed

# ========================
# SERVER CONFIGURATION
# ========================

# Port where the server will listen
PORT=5001

# Environment (development/production)
NODE_ENV=development

# ========================
# DATABASE CONFIGURATION
# ========================

# MySQL database host
DB_HOST=localhost

# MySQL database user
DB_USER=root

# MySQL database password
DB_PASSWORD=

# MySQL database name
DB_NAME=mindfreek

# Database pool size for connections
DB_POOL_SIZE=10

# ========================
# GAME CONFIGURATION
# ========================

# Number of players required for a game (2-5)
# 2 = Minimum players for solo vs someone
# 3 = Recommended for balanced gameplay
# 4-5 = More chaotic, faster rounds
PLAYERS=3

# Total number of rounds per game
# Each player gets one turn as drawer
# If 3 players: 1st draws (round 1), 2nd draws (round 2), 3rd draws (round 3)
TOTAL_ROUNDS=3

# Time limit per round (in seconds)
# 60-120 seconds recommended
# Too low: Hard to draw
# Too high: Game drags
ROUND_TIME=100

# ========================
# TIMING CONFIGURATION
# ========================

# Countdown before game starts (in seconds)
# Shows all players before starting
PRE_GAME_COUNTDOWN=10

# How long to show the "Turn Complete" popup (in seconds)
# Shows scores and next drawer
TURN_POPUP_DURATION=10

# Delay before cleaning up game data after game ends (in seconds)
# Allows players to see final scores
GAME_OVER_CLEANUP_DELAY=3

# Matchmaking search timeout (in seconds)
# How long to wait before auto-starting with fewer players
MATCH_SEARCH_TIMEOUT=30

# ========================
# PERFORMANCE & LIMITS
# ========================

# Maximum concurrent connections per server
MAX_CONNECTIONS=100

# Maximum API request timeout (in ms)
REQUEST_TIMEOUT=30000

# Maximum socket connection timeout (in ms)
SOCKET_TIMEOUT=30000

# ========================
# SECURITY CONFIGURATION
# ========================

# Maximum rooms per IP address
MAX_ROOMS_PER_IP=5

# Maximum players per IP address
MAX_PLAYERS_PER_IP=3

# Ban duration for abuse (in ms, default 1 hour)
BAN_DURATION_MS=3600000

# ========================
# INPUT VALIDATION
# ========================

# Minimum username length
MIN_USERNAME_LENGTH=2

# Maximum username length
MAX_USERNAME_LENGTH=20

# Minimum word length in dictionary
MIN_WORD_LENGTH=2

# Maximum word length
MAX_WORD_LENGTH=50

# Maximum guess/message length
MAX_GUESS_LENGTH=100
